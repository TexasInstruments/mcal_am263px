<plugin>
    <extension point="dreisoft.tresos.launcher2.plugin.module"
             id="Pwm_TI_AM263Px_ModuleId"
             name="Pwm_TI_AM263Px Module">

    <module id="Pwm_TI_AM263Px"
            label="Pwm"
            mandatory="false"
            allowMultiple="false"
            description="TI Sitara MCU AM263Px Pwm plug-in"
            copyright="(c) 2023 Texas Instruments Incorporated"
            swVersionMajor="10"
            swVersionMinor="1"
            swVersionPatch="0"
            swVersionSuffix=""
            specVersionMajor="4"
            specVersionMinor="3"
            specVersionPatch="1"
            specVersionSuffix=""
            relVersionPrefix="AUTOSAR"
            relVersionMajor="4"
            relVersionMinor="3"
            relVersionPatch="1"
            relVersionSuffix="0"
            categoryType="Pwm"
            categoryLayer="Microcontroller Drivers"
            categoryCategory="PWM"
            categoryComponent="ECUC">
      <ecuType target="ARM" derivate="AM263Px"/>
    </module>
  </extension>


    <extension point="dreisoft.tresos.launcher2.plugin.configuration"
             id="Pwm_TI_AM263Px_ConfigId"
             name="Pwm_TI_AM263Px Configuration">
    <configuration moduleId="Pwm_TI_AM263Px">
      <schema>
        <manager class="dreisoft.tresos.autosar2.resourcehandling.AutosarSchemaManager"/>
        <resource value="config/Pwm.xdm" type="xdm" id="res_default"/>
                              
        <resource value="config_ext/Pwm_Rec.xdm" type="xdm" id="res_recconf"/>
        
            <recconfig name="Default Recommended Configuration"
                   default="true"
                   description="Default Recommended Configuration"
                   resourceId="res_recconf"
                   path="ASPath:/TI_AM263Px/Pwm_Rec"/>
      </schema>

      <data>
        <manager class="dreisoft.tresos.autosar2.resourcehandling.AutosarConfigManager"/>
        <schemaNode path="ASPath:/TI_AM263Px/Pwm"/>
      </data>

      <editor id="Pwm_TI_AM263Px_EditorId"
              label="Default"
              tooltip="TI Sitara MCU Pwm plug-in">
        <class class="dreisoft.tresos.launcher2.editor.GenericConfigEditor">
          <parameter name="schema" value="ASPath:/TI_AM263Px/Pwm"/>
          <parameter name="title" value="Pwm"/>
          <parameter name="noTabs" value="false"/>
          <parameter name="noLinks" value="true"/>
          <parameter name="groupLinks" value="false"/>
          <parameter name="groupContainers" value="false"/>
          <parameter name="groupTables" value="true"/>
          <parameter name="optionalGeneralTab" value="true"/>
        </class>
      </editor>
    </configuration>
  </extension>
  <extension point="dreisoft.tresos.launcher2.plugin.generator"
              id="Pwm_TI_AM263Px_GeneratorId"
              name="Pwm_TI_AM263Px Generator">
    <generator 
               class="dreisoft.tresos.launcher2.generator.TemplateBasedCodeGenerator"
               id="PwmGenerator_AM263Px"
               moduleId="Pwm_TI_AM263Px">

      <!-- common template path parameters -->
      <parameter name="templates"
                 mode="generate,verify" value="generate,generate_swcd"/>
    </generator>
  </extension>

 
  <extension point="org.eclipse.help.toc">
    <toc file="anchors.xml" primary="true"/>
  </extension>
</plugin>

